{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": { "source.fixAll.eslint": "explicit" },
  "eslint.useFlatConfig": true,
  "files.eol": "\n",
  "search.exclude": {
    "dist": true,
    "coverage": true,
    "artifacts": true,
    ".debug-profiles": true,
    "pnpm-lock.yaml": true
  }
}
